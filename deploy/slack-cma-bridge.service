[Unit]
Description=Relay multi-agent Slack <-> Claude Managed Agents bridge
Documentation=https://github.com/shanerlevy-debug/Relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=slackbridge
Group=slackbridge
WorkingDirectory=/opt/slack-cma-bridge
EnvironmentFile=/etc/slack-cma-bridge/bridge.env
ExecStart=/opt/slack-cma-bridge/.venv/bin/python /opt/slack-cma-bridge/bridge.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/slack-cma-bridge

[Install]
WantedBy=multi-user.target
