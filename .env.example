# Copy to .env and fill in real values. .env is gitignored.
#
# On a Lightsail deploy, this same file lives at /etc/slack-cma-bridge/bridge.env
# (chmod 600) and is loaded by the systemd unit. Same shape, same secrets.
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional overrides
AGENTS_CONFIG=./agents.yaml
DB_PATH=./threads.db
SLASH_COMMAND=/ask
LOG_EVENT_TYPES=0
